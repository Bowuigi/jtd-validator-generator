{
  "minimumDependencyAge": "P3D",
  "exports": "./src/entrypoint.ts",
  "lint": {
    "include": [
      "./tests/",
      "./src/"
    ],
    "rules": {
      "tags": [
        "recommended",
        "jsr"
      ],
      "include": [
        "explicit-function-return-type",
        "explicit-module-boundary-types",
        "no-await-in-loop",
        "no-console",
        "no-eval",
        "no-external-import",
        "no-inferrable-types",
        "no-node-globals",
        "no-non-null-asserted-optional-chain",
        "no-non-null-assertion",
        "no-process-global",
        "no-self-compare",
        "no-sync-fn-in-async-fn",
        "no-undef",
        "no-useless-rename",
        "prefer-ascii",
        "single-var-declarator",
        "triple-slash-reference",
        "no-throw-literal",
        "eqeqeq",
        "no-sparse-arrays",
        "default-param-last"
      ]
    }
  },
  "fmt": {
    "include": [
      "./tests/",
      "./src/"
    ],
    "useTabs": false,
    "indentWidth": 2,
    "singleQuote": true,
    "lineWidth": 100,
    "semiColons": true,
    "trailingCommas": "never",
    "typeLiteral.separatorKind": "comma"
  },
  "compilerOptions": {
    "lib": [
      "esnext.full"
    ],
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "strict": true
  }
}
